generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   OrganizationMember[]
  projects  Project[]
  githubIntegrations GitHubIntegration[]
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  githubId  String?
  passwordHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   OrganizationMember[]
  githubIntegrations GitHubIntegration[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("developer")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String       @default("")
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  services       Service[]
  resources      Resource[]
  domains        Domain[]
  environmentVariables EnvironmentVariable[]

  @@unique([organizationId, slug])
}

model Service {
  id           String       @id @default(cuid())
  projectId    String
  name         String
  slug         String
  type         String
  runtimeType  String       @default("container")
  sourceType   String
  buildMode    String?
  repoUrl      String?
  branch       String?
  imageUrl     String?
  port         Int?
  status       String       @default("created")
  desiredState Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments  Deployment[]
  domains      Domain[]
  environmentVariables EnvironmentVariable[]

  @@unique([projectId, slug])
}

model SecretValue {
  id          String   @id @default(cuid())
  scopeType   String
  scopeId     String
  key         String
  sealedValue String
  valueMasked String
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scopeType, scopeId, key])
  @@index([scopeType, scopeId])
}

model EnvironmentVariable {
  id          String   @id @default(cuid())
  projectId   String
  serviceId   String
  key         String
  value       String?
  isSecret    Boolean  @default(false)
  valueMasked String
  secretRef   String?
  source      String   @default("api")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, key])
  @@index([projectId])
}

model GitHubIntegration {
  id               String       @id @default(cuid())
  organizationId   String
  userId           String?
  accountLogin     String?
  installationId   String?
  tokenPreview     String?
  tokenFingerprint String?
  scopes           Json?
  defaultBranch    String       @default("main")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([installationId])
}

model Resource {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  type         String
  engine       String
  provider     String
  plan         String
  region       String
  status       String   @default("provisioning")
  desiredState Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

model Deployment {
  id             String    @id @default(cuid())
  serviceId      String
  commitHash     String?
  imageUrl       String?
  status         String    @default("queued")
  deploymentType String    @default("production")
  branch         String    @default("main")
  previewUrl     String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  service        Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Domain {
  id        String   @id @default(cuid())
  projectId String
  serviceId String?
  domain    String   @unique
  verified  Boolean  @default(false)
  tlsStatus String   @default("pending")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model UsageRecord {
  id             String   @id @default(cuid())
  organizationId String
  metric         String
  quantity       Float
  unit           String
  labels         Json?
  recordedAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())
}

model WorkflowJob {
  id          String    @id @default(cuid())
  type        String
  status      String    @default("queued")
  targetType  String
  targetId    String
  payload     Json
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAfter    DateTime  @default(now())
  lockedBy    String?
  lockedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAfter])
  @@index([targetType, targetId])
}
