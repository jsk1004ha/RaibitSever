# RAIBITSERVER environment example
# Copy to .env for local development. Do not commit real .env files or real secrets.
# Production requires strong random secrets and real infrastructure endpoints.

# -----------------------------------------------------------------------------
# Runtime mode / API
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
RAIBITSERVER_MAX_BODY_BYTES=1048576

# API auth/session. In production, JWT/encryption values must be 32+ chars.
RAIBITSERVER_AUTH_JWT_SECRET=change-me-local-jwt-secret-at-least-32-chars
RAIBITSERVER_AUTH_ISSUER=raibitserver
RAIBITSERVER_AUTH_AUDIENCE=raibitserver-api
RAIBITSERVER_AUTH_RATE_LIMIT=10
RAIBITSERVER_SESSION_TTL_SECONDS=86400
RAIBITSERVER_SECRET_ENCRYPTION_KEY=change-me-local-encryption-key-32chars
RAIBITSERVER_ADMIN_BOOTSTRAP_TOKEN=change-me-production-bootstrap-token-32chars
ADMIN_EMAILS=admin@example.com

# Local-only auth bypass. Never enable in production.
RAIBITSERVER_AUTH_DISABLED=0
RAIBITSERVER_AUTH_DISABLED_CONFIRM=
RAIBITSERVER_AUTH_DEV_HEADERS=0
RAIBITSERVER_DEV_HEADER_BIND_LOCAL=0
RAIBITSERVER_AUTH_DEV_TOKEN=0
RAIBITSERVER_ROLE=owner
RAIBITSERVER_PERMISSION=

# -----------------------------------------------------------------------------
# Control-plane persistence
# -----------------------------------------------------------------------------
# Local default can use the in-memory/file store. Production should use prisma.
RAIBITSERVER_PERSISTENCE=memory
RAIBITSERVER_CONTROL_PLANE_STORE=memory
RAIBITSERVER_CONTROL_PLANE_FILE=.raibitserver-work/control-plane.json
RAIBITSERVER_STATE_FILE=.raibitserver-work/control-plane.json
RAIBITSERVER_WORKFLOW_STATE=.raibitserver-work/control-plane.json

# PostgreSQL control-plane DB. Required for production Prisma persistence.
DATABASE_URL=postgresql://raibitserver:raibitserver@localhost:5432/raibitserver?schema=public
RAIBITSERVER_CONTROL_PLANE_DATABASE_URL=postgresql://raibitserver:raibitserver@localhost:5432/raibitserver?schema=public
RAIBITSERVER_ALLOW_MEMORY_PERSISTENCE=0

# -----------------------------------------------------------------------------
# Dashboard / API client
# -----------------------------------------------------------------------------
RAIBITSERVER_API_URL=http://localhost:3000/api
RAIBITSERVER_TOKEN=dev-dashboard-token
RAIBITSERVER_DASHBOARD_TOKEN=dev-dashboard-token
# Format: username:password. Required when a server-side dashboard token is exposed publicly.
RAIBITSERVER_DASHBOARD_BASIC_AUTH=admin:change-me

# -----------------------------------------------------------------------------
# Domains / Kubernetes runtime
# -----------------------------------------------------------------------------
BASE_DOMAIN=raibitserver.local
RAIBITSERVER_BASE_DOMAIN=raibitserver.local
KUBECONFIG=
RAIBITSERVER_KUBE_CONTEXT=
RAIBITSERVER_ORCHESTRATOR_OUTPUT_DIR=.raibitserver-work/orchestrator
RAIBITSERVER_ROLLOUT_TIMEOUT_SECONDS=300

# Dry-run is the safe default. Set RAIBITSERVER_EXECUTE=1 only for explicit live runs.
RAIBITSERVER_DRY_RUN=1
RAIBITSERVER_EXECUTE=0

# -----------------------------------------------------------------------------
# Builder / registry
# -----------------------------------------------------------------------------
REGISTRY_URL=localhost:5000/raibitserver
RAIBITSERVER_REGISTRY=localhost:5000
RAIBITSERVER_REGISTRY_USERNAME=
RAIBITSERVER_REGISTRY_PASSWORD=
RAIBITSERVER_PUSH=0
RAIBITSERVER_BUILDER=docker-buildx
RAIBITSERVER_BUILD_MODE=auto
RAIBITSERVER_BUILD_TIMEOUT_SECONDS=900
RAIBITSERVER_WORKER_ID=raibitserver-builder-local
RAIBITSERVER_WORKSPACE=.raibitserver-work/builder
RAIBITSERVER_WORKFLOW_LEASE_SECONDS=300
RAIBITSERVER_BUILD_METADATA_DIR=.raibitserver-work/build-metadata

# Optional BuildKit registry cache. Use a writable registry ref for live builders.
RAIBITSERVER_BUILDKIT_CACHE=inline
RAIBITSERVER_BUILDKIT_CACHE_REF=localhost:5000/raibitserver/buildcache:latest

# Optional explicit build source/image overrides for local worker experiments.
RAIBITSERVER_SOURCE=
RAIBITSERVER_IMAGE=
RAIBITSERVER_ALLOWED_GIT_HOSTS=github.com,gitlab.com,bitbucket.org
RAIBITSERVER_ALLOW_LOCAL_SOURCE=1

# -----------------------------------------------------------------------------
# Resource providers / DBaaS
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
RAIBITSERVER_POSTGRES_PROVIDER_URL=postgresql://provider:provider@localhost:5432/postgres
POSTGRES_PROVIDER_URL=postgresql://provider:provider@localhost:5432/postgres
RAIBITSERVER_POSTGRES_POOLER_HOST=pgbouncer.shared-providers.svc.cluster.local
# Live provider provisioning is disabled unless this is exactly true.
RAIBITSERVER_ENABLE_LIVE_PROVIDER_PROVISIONING=false
RAIBITSERVER_CONFIRMED=false

# Object storage / S3-compatible provider
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=raibitserver
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# GitHub OAuth / GitHub App / webhooks
# -----------------------------------------------------------------------------
RAIBITSERVER_GITHUB_CLIENT_ID=
RAIBITSERVER_GITHUB_CLIENT_SECRET=
RAIBITSERVER_GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback
RAIBITSERVER_GITHUB_OAUTH_LOCAL_CALLBACK=1
RAIBITSERVER_GITHUB_WEBHOOK_SECRET=change-me-webhook-secret

# Legacy/worker-compatible GitHub names used by scripts and integrations.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Local E2E
# -----------------------------------------------------------------------------
RAIBITSERVER_E2E_MODE=dry
